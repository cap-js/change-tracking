{
  "dependencies": {
    "@cap-js/change-tracking": "file:../../.",
    "@sap/cds-mtxs": ">=3"
  },
  "devDependencies": {
    "@cap-js/sqlite": ">=2",
    "better-sqlite3": ">=12"
  },
  "cds": {
    "sqlite": {
      "driver": "better-sqlite3"
    },
    "requires": {
      "db": {
        "kind": "sql"
      },
      "[production]": {
        "multitenancy": true,
        "extensibility": true
      },
      "[with-mtx]": {
        "multitenancy": true
      },
      "toggles": true,
      "extensibility": true
    },
    "features": {
      "serve_on_root": true
    },
    "profile": "with-mtx-sidecar"
  }
}
